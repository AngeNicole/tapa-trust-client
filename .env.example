# Copy this file to .env and fill in the value. Never commit .env.
# Vite only exposes variables prefixed with VITE_ to the client.

# Base URL of the backend API, including the trailing /api path.
#   Local:    http://localhost:4000/api
#   Deployed: https://your-server.onrender.com/api
VITE_API_URL=http://localhost:4000/api
